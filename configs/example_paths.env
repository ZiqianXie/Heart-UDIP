# Example paths for local execution.
# Copy to a private file such as configs/local.env and edit as needed.

RAW_DICOM_DIR=/path/to/dicom_root
RAW_NIFTI_DIR=/path/to/nii_files
SEGMENTATION_MASK_DIR=/path/to/nnunet_masks
CROPPED_NIFTI_DIR=/path/to/cropped_80x80x50
REGISTERED_NIFTI_DIR=/path/to/registered_volumes
TEMPLATE_PATH=/path/to/template_150_zfixed.nii.gz
MODEL_WEIGHTS=/path/to/model_epoch_100.pth
LATENT_CSV=/path/to/latent_features.csv
